{
  "name": "harbor",
  "private": true,
  "version": "0.1.9",
  "type": "module",
  "scripts": {
    "bump": "node scripts/bump-version.mjs",
    "dev": "npm run tauri -- dev",
    "dev:frontend": "node scripts/prepare-bundled-defaults.mjs && vite",
    "build": "node scripts/prepare-bundled-defaults.mjs && tsc && vite build",
